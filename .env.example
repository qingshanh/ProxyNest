HOST=0.0.0.0
PORT=8080
DATA_DIR=./data
WEB_DIST_DIR=./apps/web/dist
PUBLIC_BASE_URL=http://localhost:8080
ADMIN_PASSWORD=change-me-before-start
COOKIE_SECRET=change-me-to-a-long-random-string
SESSION_TTL_DAYS=30

# Optional. If set, real node probing can use mihomo.
MIHOMO_BIN=
MIHOMO_API_SECRET=proxynest
MIHOMO_BASE_PORT=17890
MIHOMO_BASE_CONTROLLER_PORT=17990

# Optional Telegram notification.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Optional GitHub discovery and raw proxy.
GITHUB_TOKEN=
GITHUB_RAW_PROXY_PREFIX=https://gha.980999.xyz/
